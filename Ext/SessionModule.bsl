
Процедура УстановкаПараметровСеанса(ТребуемыеПараметры)

  // Получаем имя текущего пользователя информационной базы
    ИмяПользователяИБ = ПользователиИнформационнойБазы.ТекущийПользователь().ПолноеИмя;

    // Формируем запрос с объединением справочников и регистра
    Запрос = Новый Запрос;
    Запрос.Текст =
        "ВЫБРАТЬ
        |    СкладыПользователей.Склад КАК Склад
        |ИЗ
        |    Справочник.Сотрудники КАК Сотрудники
        |        ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СкладыПользователей КАК СкладыПользователей
        |        ПО Сотрудники.Ссылка = СкладыПользователей.Пользователь
        |ГДЕ
        |    Сотрудники.Наименование = &ИмяПользователя";

    Запрос.УстановитьПараметр("ИмяПользователя", ИмяПользователяИБ);

    // Выполняем запрос и получаем результат
    Результат = Запрос.Выполнить();
    Выборка = Результат.Выбрать();

    Если Выборка.Следующий() Тогда
        Склад = Выборка.Склад;

        // Безопасная проверка: сначала тип, потом пустая ссылка
        Если ТипЗнч(Склад) = Тип("СправочникСсылка.Склады") И Не Склад.Пустая() Тогда
            ПараметрыСеанса.ТекущийСклад = Склад;
        Иначе
            ПараметрыСеанса.ТекущийСклад = Справочники.Склады.ПустаяСсылка();
        КонецЕсли;
    Иначе
        // Если запись не найдена, устанавливаем пустую ссылку
        ПараметрыСеанса.ТекущийСклад = Справочники.Склады.ПустаяСсылка();
	КонецЕсли;
	
КонецПроцедуры

